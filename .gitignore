# vibecodeweb .gitignore
# Simple static site — tracking everything including images (only 12MB).

# OS / editor noise
Thumbs.db
.DS_Store
*.swp
desktop.ini
__pycache__/
*.pyc

# Instagram automation — secrets & runtime artifacts (NEVER commit these)
ig-automation/config.php
ig-automation/logs/
ig-automation/*.token
ig-automation/token.json
